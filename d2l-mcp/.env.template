# D2L Brightspace Configuration
D2L_HOST=learn.yourschool.edu
D2L_COURSE_ID=                    # Optional: default course ID for tools
D2L_USERNAME=                     # Optional: for automated login
D2L_PASSWORD=                     # Optional: for automated login

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Piazza Integration (optional)
PIAZZA_USERNAME=your-email@school.edu
PIAZZA_PASSWORD=your-piazza-password

# OpenAI (required for semantic search embeddings)
OPENAI_API_KEY=sk-your-openai-api-key

# S3 (required for browser state persistence)
S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1

# Cognito (optional, for mobile app auth)
COGNITO_USER_POOL_ID=your-pool-id
COGNITO_CLIENT_ID=your-client-id

# Server
API_HOST=your-domain.com
MCP_TRANSPORT=http
MCP_PORT=3000

# Dev mode (local only — never set these in production)
# SKIP_JWT_AUTH=1
# MCP_USER_ID=test-user
