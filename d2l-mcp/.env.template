# D2L Brightspace Configuration
D2L_HOST=learn.yourschool.edu
D2L_COURSE_ID=                    # Optional: default course ID for tools
D2L_USERNAME=                     # Optional: for automated login
D2L_PASSWORD=                     # Optional: for automated login

# Supabase (required for study tools: tasks, notes, piazza sync)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Piazza Integration (optional: for piazza tools)
PIAZZA_USERNAME=your-email@school.edu
PIAZZA_PASSWORD=your-piazza-password

# OpenAI (required for semantic search embeddings)
OPENAI_API_KEY=sk-your-openai-api-key

# MCP Token (Auth):
STUDY_MCP_TOKEN=some-long-random-string

# Notes Repository (optional: for notes sync)
# NOTES_REPO_PATH is not needed if notes_map.json uses absolute paths
NOTES_REPO_WEB_BASE=https://github.com/user/repo/blob/main/